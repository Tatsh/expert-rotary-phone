<?xml version="1.0" encoding="UTF-8" ?>
<!--
  Info.plist template for pop'n rhythmin. Consumed by CMake (configure_file @ONLY),
  which substitutes the @...@ placeholders. The original bundle's own Info.plist is
  NOT reused (it references the 64-bit-less Mach-O and Konami provisioning); this one
  reproduces the keys the reconstructed code actually reads at runtime, chiefly
  CFBundleVersion (AppDelegate reads infoDictionary[@"CFBundleVersion"]).
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleDisplayName</key>
    <string>@APP_DISPLAY_NAME@</string>
    <key>CFBundleName</key>
    <string>PopnRhythmin</string>
    <key>CFBundleExecutable</key>
    <string>PopnRhythmin</string>
    <key>CFBundleIdentifier</key>
    <string>@APP_BUNDLE_ID@</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>@APP_VERSION@</string>
    <key>CFBundleVersion</key>
    <string>@APP_BUILD@</string>
    <key>LSRequiresIPhoneOS</key>
    <true />
    <key>MinimumOSVersion</key>
    <string>@IOS_DEPLOYMENT_TARGET@</string>

    <!-- Do NOT require a specific CPU arch here: this rebuild ships both 32-bit
         (armv7/armv7s) and 64-bit (arm64/arm64e) slices, and requiring "armv7" would
         block installation on the arm64-only iOS 11+ devices this reconstruction exists
         to reach. Only the real hardware requirement (OpenGL ES 2) is asserted. -->
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>opengles-2</string>
    </array>

    <!-- iPhone + iPad (device family) is set via the TARGETED_DEVICE_FAMILY build
         setting in CMakeLists.txt; Xcode overwrites any UIDeviceFamily key here. -->

    <!-- The game runs full-screen only (no multitasking / Slide Over). Declaring
         this is also what lets us ship without a launch storyboard or xib. -->
    <key>UIRequiresFullScreen</key>
    <true />

    <!-- Rhythm gameplay runs full-screen; allow both portrait and landscape and let the
         controllers drive it. Adjust if the shipped app was orientation-locked. -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- App Transport Security exceptions for the game's servers. Generated by
         CMake from the APR_HOST / APR_SECURE_HOST / OFFICIAL_HOST cache variables
         (deduplicated). Lets the endpoints be reached on modern iOS, where ATS
         otherwise blocks weak-TLS / cleartext loads. -->
@APP_TRANSPORT_SECURITY@

    <key>UIStatusBarHidden</key>
    <true />
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false />

    <!-- App icon. This bundle predates asset catalogs, so the home-screen icon
         comes from the loose AppIcon*.png files (shipped with the game assets)
         referenced here by CFBundleIcons using their base names; iOS resolves the
         @2x and ~ipad variants. Without this the built app installs with a blank
         icon even though the PNGs are present in the bundle. -->
    <key>CFBundleIcons</key>
    <dict>
        <key>CFBundlePrimaryIcon</key>
        <dict>
            <key>CFBundleIconFiles</key>
            <array>
                <string>AppIcon29x29</string>
                <string>AppIcon57x57</string>
                <string>AppIcon60x60</string>
            </array>
        </dict>
    </dict>
    <key>CFBundleIcons~ipad</key>
    <dict>
        <key>CFBundlePrimaryIcon</key>
        <dict>
            <key>CFBundleIconFiles</key>
            <array>
                <string>AppIcon29x29</string>
                <string>AppIcon40x40</string>
                <string>AppIcon50x50</string>
                <string>AppIcon57x57</string>
                <string>AppIcon72x72</string>
                <string>AppIcon76x76</string>
            </array>
        </dict>
    </dict>
</dict>
</plist>
